# Copy to .env on the server:  cp .env.production.example .env
# These values are injected into the backend container by docker-compose.

# Mongo database name (data persists in the mongo_data docker volume)
MONGODB_DATABASE=eva_2

# CORS: same-origin deploy doesn't need it, but set your server origin to be safe.
# Example: http://203.0.113.10
CORS_ORIGINS=http://localhost

# Admin panel password (/admin). CHANGE THIS for a public demo.
ADMIN_PASSWORD=changeme

# Yandex GPT credentials for the AI chat. Leave empty to disable AI.
YANDEX_FOLDER_ID=
YANDEX_API_KEY=
YANDEX_MODEL=yandexgpt
